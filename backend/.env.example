DATABASE_URL="postgresql://postgres:password@localhost:5432/nexusai"
JWT_SECRET="nexusai-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# AI Engine (OpenAI-compatible)
AI_API_BASE="https://api.ai-box.vn/v1"
AI_API_KEY="your-api-key-here"
AI_MODEL="deepseek-v4-pro[1m]"
AI_SUMMARY_MODEL="gemini-2.5-flash"
AI_EMBEDDING_MODEL="text-embedding-3-small"

# Disabled by default to avoid installing Python packages during app startup.
MARKITDOWN_AUTO_INSTALL=false


# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# S3 Storage (for images — image/*)
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
S3_REGION="us-east-1"
S3_BUCKET_NAME="your-bucket-name"
S3_ENDPOINT="https://s3.custom-endpoint.com"  # optional, for MinIO/Ceph etc.
S3_PUBLIC_URL="https://cdn.example.com"        # optional, custom domain/CDN

# CORS
FRONTEND_URL="http://localhost:3000"
PORT=4000
